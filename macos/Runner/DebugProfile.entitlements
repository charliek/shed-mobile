<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- No app-sandbox: this is a personal sideload desktop tool that needs the
	     real ~/.ssh identity and unrestricted SSH/HTTPS to shed hosts. -->
	<key>com.apple.security.cs.allow-jit</key>
	<true/>
</dict>
</plist>
